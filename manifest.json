{
  "manifest_version": 3,
  "name": "TaskForge",
  "version": "0.1.0",
  "description": "Create tasks and send them to Notion and Google Tasks from a Chrome extension.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.notion.com/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "action": {
    "default_title": "TaskForge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
